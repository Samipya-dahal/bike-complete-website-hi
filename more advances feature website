<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Bike World Pro 🚴‍♂️</title>
    <style>
      /* ===== RESET ===== */
      * {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
        font-family: "Segoe UI", sans-serif;
      }
      body {
        background: linear-gradient(135deg, #983636, #333, #111);
        color: white;
        transition: 0.3s;
        overflow-x: hidden;
      }
      .light {
        background: white !important;
        color: rgb(135, 33, 33) !important;
      }
      /* ===== NAV ===== */
      nav {
        display: none;
        background: linear-gradient(90deg, #ff6600, #ffcc00, #00ccff, #6600ff);
        padding: 15px;
        justify-content: space-between;
        align-items: center;
        flex-wrap: wrap;
      }
      nav a {
        color: white;
        text-decoration: none;
        margin: 5px 10px;
        font-weight: bold;
        transition: 0.3s;
      }
      nav a:hover {
        transform: scale(1.1);
      }
      nav input {
        padding: 6px;
        border-radius: 5px;
        border: none;
      }

      /* ===== DISCOUNT BANNER ===== */
      .discount-banner {
        background: linear-gradient(90deg, #ff0000, #ff6600);
        text-align: center;
        padding: 12px;
        font-weight: bold;
        font-size: 18px;
        animation: slideDown 0.6s ease-in-out;
      }
      @keyframes slideDown {
        from {
          transform: translateY(-100%);
        }
        to {
          transform: translateY(0);
        }
      }

      /* ===== AUTH ===== */
      #authPage {
        display: flex;
        justify-content: center;
        align-items: center;
        height: 100vh;
      }
      .auth-box {
        background: #111;
        padding: 40px;
        border-radius: 15px;
        box-shadow: 0 0 25px #ff6600;
        text-align: center;
        width: 320px;
      }
      .auth-box input {
        width: 100%;
        margin: 10px 0;
        padding: 10px;
        border: none;
        border-radius: 6px;
      }
      .auth-box button {
        width: 100%;
        margin-top: 10px;
        padding: 10px;
        border: none;
        border-radius: 6px;
        background: #ff6600;
        color: white;
        cursor: pointer;
        transition: 0.3s;
      }
      .auth-box button:hover {
        opacity: 0.9;
        transform: scale(1.05);
      }
      .auth-box p {
        margin-top: 10px;
        cursor: pointer;
        color: #ff6600;
      }

      /* ===== SECTIONS ===== */
      .section {
        display: none;
        padding: 40px;
        text-align: center;
        animation: fadeIn 0.5s ease-in-out;
      }
      .active {
        display: block;
      }

      /* ===== BIKE GRID ===== */
      .bike-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
        gap: 20px;
        max-width: 1200px;
        margin: auto;
        perspective: 1000px;
      }
      .bike-card {
        background: #222;
        border-radius: 15px;
        overflow: hidden;
        transition: 0.5s;
        cursor: pointer;
        transform-style: preserve-3d;
      }
      .bike-card:hover {
        transform: rotateY(10deg) scale(1.05);
        box-shadow: 0 10px 20px rgba(0, 0, 0, 0.5);
      }
      .bike-card img {
        width: 100%;
        height: 200px;
        object-fit: cover;
        transition: 0.3s;
      }
      .bike-card h3 {
        margin: 10px 0;
      }
      .bike-card p {
        font-size: 14px;
      }
      .bike-card button {
        padding: 8px 12px;
        border: none;
        border-radius: 6px;
        background: #ff6600;
        color: white;
        cursor: pointer;
        margin: 5px;
        transition: 0.3s;
      }
      .bike-card button:hover {
        opacity: 0.9;
        transform: scale(1.05);
      }

      /* ===== CONTACT ===== */
      .contact-container {
        display: flex;
        justify-content: center;
        gap: 40px;
        flex-wrap: wrap;
      }
      .contact-info,
      .contact-form {
        background: #222;
        padding: 25px;
        border-radius: 10px;
        width: 300px;
      }
      .contact-form input,
      .contact-form textarea {
        width: 100%;
        padding: 10px;
        margin-bottom: 10px;
        border: none;
        border-radius: 6px;
      }
      textarea {
        resize: none;
        height: 90px;
      }

      /* ===== CHATBOT ===== */
      .chatbot {
        position: fixed;
        bottom: 20px;
        right: 20px;
        z-index: 999;
      }
      .chatbot button {
        font-size: 24px;
        background: #ff6600;
        color: white;
        border: none;
        border-radius: 50%;
        width: 60px;
        height: 60px;
        cursor: pointer;
        transition: 0.3s;
        animation: bounce 2s infinite;
      }
      @keyframes bounce {
        0%,
        100% {
          transform: translateY(0);
        }
        50% {
          transform: translateY(-10px);
        }
      }
      .chatbox {
        width: 300px;
        height: 350px;
        background: #111;
        display: none;
        flex-direction: column;
        border-radius: 10px;
        overflow: hidden;
        box-shadow: 0 5px 25px rgba(0, 0, 0, 0.5);
      }
      .chat-header {
        background: #ff6600;
        padding: 10px;
        font-weight: bold;
      }
      .chat-messages {
        flex: 1;
        overflow-y: auto;
        padding: 10px;
      }
      .chat-input {
        display: flex;
      }
      .chat-input input {
        flex: 1;
        padding: 10px;
      }
      .user {
        text-align: right;
        color: #ffcc00;
      }
      .bot {
        color: #00ccff;
        font-style: italic;
        animation: typing 1s infinite;
      }
      @keyframes typing {
        0%,
        100% {
          opacity: 0;
        }
        50% {
          opacity: 1;
        }
      }

      /* ===== CHECKOUT ===== */
      #cartItems p {
        margin: 5px 0;
      }
      .checkout-btn {
        padding: 10px 20px;
        border: none;
        border-radius: 6px;
        background: #00ccff;
        color: white;
        cursor: pointer;
        transition: 0.3s;
      }
      .checkout-btn:hover {
        transform: scale(1.05);
      }

      /* ===== ANIMATIONS ===== */
      @keyframes fadeIn {
        from {
          opacity: 0;
          transform: translateY(15px);
        }
        to {
          opacity: 1;
          transform: translateY(0);
        }
      }

      /* ===== RESPONSIVE ===== */
      @media (max-width: 768px) {
        nav {
          flex-direction: column;
          text-align: center;
        }
        .bike-grid {
          grid-template-columns: 1fr;
        }
        .contact-container {
          flex-direction: column;
          align-items: center;
        }
        .auth-box {
          width: 90%;
        }
      }
      @media (max-width: 600px) {
        nav div {
          margin: 5px 0;
        }
        .bike-card img {
          height: 180px;
        }
        .chatbox {
          width: 90vw;
          right: 5%;
        }
        .contact-info,
        .contact-form {
          width: 90%;
        }
        h1 {
          font-size: 22px;
        }
        .auth-box {
          padding: 25px;
        }
        .discount-banner {
          font-size: 14px;
          padding: 10px;
        }
      }
    </style>
  </head>
  <body>
    <!-- LOGIN -->
    <div id="authPage">
      <div class="auth-box">
        <h2>Login</h2>
        <input type="text" id="username" placeholder="Username" />
        <input type="password" id="password" placeholder="Password" />
        <button onclick="login()">Login</button>
        <button onclick="register()">Register</button>
        <p onclick="forgotPassword()">Forgot Password?</p>
      </div>
    </div>

    <!-- NAV -->
    <nav id="navbar">
      <div>
        <a href="#" onclick="showSection('home')">Home</a>
        <a href="#" onclick="showSection('shop')">Shop</a>
        <a href="#" onclick="showSection('contact')">Contact</a>
        <a href="#" onclick="showSection('checkout')">Checkout</a>
      </div>
      <div>
        🛒 <span id="count">0</span> | $<span id="total">0</span>
        <button onclick="toggleTheme()">🌙</button>
      </div>
    </nav>

    <!-- HOME -->
    <div id="home" class="section active">
      <h1>Welcome to Bike World 🚴</h1>
      <p>
        🚀 AI Bike Recommendation System | 3D Hover Animations | Stripe-style
        Checkout
      </p>
    </div>

    <!-- SHOP -->
    <div id="shop" class="section">
      <div class="discount-banner">🎉 Special Offer! 25% OFF All Bikes! 🎉</div>
      <h1>Bike Collection</h1>
      <div class="bike-grid" id="bikeGrid"></div>
    </div>

    <!-- CONTACT -->
    <div id="contact" class="section">
      <h1>Contact Us</h1>
      <div class="contact-container">
        <div class="contact-info">
          <p>📞 9842625154</p>
          <p>📧 sam123@gmail.com</p>
          <p>📍 Bike Street, NY</p>
        </div>
        <form class="contact-form" onsubmit="sendForm(event)">
          <input type="text" placeholder="Full Name" required />
          <input type="email" placeholder="Email" required />
          <textarea placeholder="Message" required></textarea>
          <button type="submit">Send Message</button>
        </form>
      </div>
    </div>

    <!-- CHECKOUT -->
    <div id="checkout" class="section">
      <h1>Checkout</h1>
      <div id="cartItems"></div>
      <button class="checkout-btn" onclick="placeOrder()">Place Order</button>
    </div>

    <!-- CHATBOT -->
    <div class="chatbot">
      <button onclick="toggleChat()">🤖</button>
      <div class="chatbox" id="chatbox">
        <div class="chat-header">Bike Assistant</div>
        <div class="chat-messages" id="messages"></div>
        <div class="chat-input">
          <input type="text" id="msg" />
          <button onclick="sendMsg()">Send</button>
        </div>
      </div>
    </div>

    <script>
      let cart = [];
      let users = JSON.parse(localStorage.getItem("users")) || {};
      const bikes = [
        {
          name: "Mountain Beast",
          desc: "Built for rugged terrains",
          price: 524,
          img: "moutain.jpg",
        },
        {
          name: "Urban Racer",
          desc: "Lightweight for speed",
          price: 449,
          img: "urban.jpg",
        },
        {
          name: "Electric Pro",
          desc: "Eco-friendly commuting",
          price: 374,
          img: "electric.jpg",
        },
        {
          name: "Yamaha Bike",
          desc: "Reliable & advanced engineering",
          price: 956,
          img: "yamaha.jpg",
        },
        {
          name: "Honda",
          desc: "Reliable engine",
          price: 374,
          img: "Honda.jpg",
        },
        {
          name: "Honda 150cc Racer",
          desc: "Speed & racing",
          price: 374,
          img: "honda 15022.jpg",
        },
      ];

      // Generate bike cards
      const bikeGrid = document.getElementById("bikeGrid");
      bikes.forEach((bike) => {
        const card = document.createElement("div");
        card.className = "bike-card";
        card.innerHTML = `<img src="${bike.img}" />
          <h3>${bike.name}</h3>
          <p>${bike.desc}</p>
          <p><span style="text-decoration: line-through; color: gray">$${bike.price}</span>
          <span style="color: #00ff99; font-weight: bold">$${Math.round(bike.price * 0.75)}</span></p>
          <button onclick="addCart('${bike.name}',${bike.price})">Add to Cart</button>`;
        bikeGrid.appendChild(card);
      });

      // ===== REGISTER =====
      function register() {
        const u = document.getElementById("username").value.trim();
        const p = document.getElementById("password").value.trim();
        if (u.length < 3 || p.length < 4) {
          alert("Username min 3 & password min 4");
          return;
        }
        let email = prompt("Enter your email for recovery:");
        if (!email || !email.includes("@")) {
          alert("Enter valid email!");
          return;
        }
        users[u] = { password: p, email: email };
        localStorage.setItem("users", JSON.stringify(users));
        alert("Registered! Login now.");
      }

      // ===== LOGIN =====
      function login() {
        users = JSON.parse(localStorage.getItem("users")) || {};
        const u = document.getElementById("username").value.trim();
        const p = document.getElementById("password").value.trim();
        if (!users[u]) {
          alert("User not found!");
          return;
        }
        if (users[u].password === p) {
          document.getElementById("authPage").style.display = "none";
          document.getElementById("navbar").style.display = "flex";
          showSection("home");
        } else alert("Wrong Password!");
      }

      // ===== FORGOT PASSWORD =====
      function forgotPassword() {
        users = JSON.parse(localStorage.getItem("users")) || {};
        const email = prompt("Enter your registered email:");
        let foundUser = null;
        for (let u in users) {
          if (users[u].email === email) foundUser = u;
        }
        if (!foundUser) {
          alert("Email not found!");
          return;
        }

        const code = Math.floor(100000 + Math.random() * 900000);
        localStorage.setItem("resetCode", code);
        localStorage.setItem("resetUser", foundUser);
        alert(`Your password reset code is: ${code} (simulated email)`);

        const enteredCode = prompt("Enter the code sent to your email:");
        if (parseInt(enteredCode) !== code) {
          alert("Incorrect code!");
          return;
        }

        const newPassword = prompt("Enter your new password (min 4 chars):");
        if (!newPassword || newPassword.length < 4) {
          alert("Invalid password!");
          return;
        }
        users[foundUser].password = newPassword;
        localStorage.setItem("users", JSON.stringify(users));
        alert("Password reset successfully! You can now login.");
      }

      // ===== SECTIONS =====
      function showSection(id) {
        document
          .querySelectorAll(".section")
          .forEach((s) => s.classList.remove("active"));
        document.getElementById(id).classList.add("active");
        if (id === "checkout") renderCart();
      }

      // ===== CART =====
      function addCart(name, price) {
        const discounted = Math.round(price * 0.75);
        cart.push({ name, price: discounted });
        updateCart();
      }
      function updateCart() {
        document.getElementById("count").innerText = cart.length;
        document.getElementById("total").innerText = cart.reduce(
          (sum, i) => sum + i.price,
          0,
        );
      }
      function renderCart() {
        const box = document.getElementById("cartItems");
        box.innerHTML = "";
        cart.forEach(
          (i) => (box.innerHTML += `<p>${i.name} - $${i.price}</p>`),
        );
      }
      function placeOrder() {
        if (cart.length === 0) {
          alert("Cart is empty!");
          return;
        }
        alert("Order placed successfully!");
        cart = [];
        updateCart();
        renderCart();
      }

      // ===== DARK MODE =====
      function toggleTheme() {
        document.body.classList.toggle("light");
      }

      // ===== CONTACT FORM =====
      function sendForm(e) {
        e.preventDefault();
        alert("Message Sent!");
        e.target.reset();
      }

      // ===== CHATBOT =====
      function toggleChat() {
        const box = document.getElementById("chatbox");
        box.style.display = box.style.display === "flex" ? "none" : "flex";
      }
      function sendMsg() {
        const input = document.getElementById("msg");
        const text = input.value.trim();
        if (!text) return;
        addMessage(text, "user");
        let reply = "Ask about price or discount.";
        const t = text.toLowerCase();
        if (t.includes("price"))
          reply = "Prices range $280 to $717 after 25% discount.";
        else if (t.includes("discount")) reply = "All bikes have 25% discount!";
        else if (t.includes("hi")) reply = "Hello Rider 🚴";
        else if (t.includes("bikes"))
          reply = "We have Mountain, Urban, Electric, Yamaha & Honda bikes.";
        else if (t.includes("mountain"))
          reply = "Mountain Beast perfect for rugged terrains.";
        else if (t.includes("urban"))
          reply = "Urban Racer is designed for city commuting.";
        else if (t.includes("electric"))
          reply = "Electric Pro for eco-friendly assisted riding.";
        else if (t.includes("yamaha"))
          reply = "Yamaha bike: premium & reliable.";
        else if (t.includes("honda"))
          reply = "Honda bikes are affordable & practical.";
        else if (t.includes("racer"))
          reply = "Honda 150cc Racer: built for speed & racing.";
        setTimeout(() => addMessage(reply, "bot"), 500);
        input.value = "";
      }
      function addMessage(text, type) {
        const div = document.createElement("div");
        div.className = type;
        div.innerText = text;
        document.getElementById("messages").appendChild(div);
        div.scrollIntoView({ behavior: "smooth" });
      }
    </script>
  </body>
</html>
