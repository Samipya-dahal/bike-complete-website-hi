<!doctype html>
<html>
  <head>
    <meta charset="UTF-8" />
    <title>Bike World Pro</title>

    <style>
      * {
        box-sizing: border-box;
      }

      body {
        margin: 0;
        font-family:
          Segoe UI,
          sans-serif;
        background: linear-gradient(135deg, #1a1a1a, #333, #111);
        color: white;
        transition: 0.3s;
      }
      .light {
        background: white !important;
        color: black !important;
      }

      nav {
        display: none;
        background: linear-gradient(90deg, #ff6600, #ffcc00, #00ccff, #6600ff);
        padding: 15px;
        justify-content: space-between;
        align-items: center;
        flex-wrap: wrap;
      }
      nav a {
        color: white;
        text-decoration: none;
        margin: 5px 10px;
        font-weight: bold;
      }
      nav input {
        padding: 6px;
        border-radius: 5px;
        border: none;
      }

      #authPage {
        display: flex;
        justify-content: center;
        align-items: center;
        height: 100vh;
      }
      .auth-box {
        background: #111;
        padding: 40px;
        border-radius: 15px;
        box-shadow: 0 0 25px #ff6600;
        text-align: center;
        width: 320px;
      }
      .auth-box input {
        width: 100%;
        margin: 10px 0;
        padding: 10px;
        border: none;
        border-radius: 6px;
      }
      .auth-box button {
        width: 100%;
        margin-top: 10px;
        padding: 10px;
        border: none;
        border-radius: 6px;
        background: #ff6600;
        color: white;
        cursor: pointer;
      }
      .auth-box button:hover {
        opacity: 0.9;
      }

      .section {
        display: none;
        padding: 40px;
        text-align: center;
        animation: fadeIn 0.4s ease-in-out;
      }
      .active {
        display: block;
      }

      .bike-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
        gap: 20px;
        max-width: 1000px;
        margin: auto;
      }
      .bike-card {
        background: #222;
        border-radius: 15px;
        overflow: hidden;
        transition: 0.3s;
      }
      .bike-card:hover {
        transform: scale(1.05);
      }
      .bike-card img {
        width: 100%;
        height: 200px;
        object-fit: cover;
      }
      button {
        padding: 8px 12px;
        border: none;
        border-radius: 6px;
        background: #ff6600;
        color: white;
        cursor: pointer;
        margin: 5px;
      }
      button:hover {
        opacity: 0.9;
      }

      .contact-container {
        display: flex;
        justify-content: center;
        gap: 40px;
        flex-wrap: wrap;
      }
      .contact-info,
      .contact-form {
        background: #222;
        padding: 25px;
        border-radius: 10px;
        width: 300px;
      }
      .contact-form input,
      .contact-form textarea {
        width: 100%;
        padding: 10px;
        margin-bottom: 10px;
        border: none;
        border-radius: 6px;
      }
      textarea {
        resize: none;
        height: 90px;
      }

      .chatbot {
        position: fixed;
        bottom: 20px;
        right: 20px;
      }
      .chatbox {
        width: 300px;
        height: 350px;
        background: #111;
        display: none;
        flex-direction: column;
        border-radius: 10px;
      }
      .chat-header {
        background: #ff6600;
        padding: 10px;
      }
      .chat-messages {
        flex: 1;
        overflow-y: auto;
        padding: 10px;
      }
      .chat-input {
        display: flex;
      }
      .chat-input input {
        flex: 1;
        padding: 10px;
        border: none;
      }
      .user {
        text-align: right;
        color: #ffcc00;
      }
      .bot {
        color: #00ccff;
      }

      @keyframes fadeIn {
        from {
          opacity: 0;
          transform: translateY(15px);
        }
        to {
          opacity: 1;
          transform: translateY(0);
        }
      }

      @media (max-width: 768px) {
        nav {
          flex-direction: column;
          text-align: center;
        }
        .bike-grid {
          grid-template-columns: 1fr;
        }
        .contact-container {
          flex-direction: column;
          align-items: center;
        }
        .auth-box {
          width: 90%;
        }
      }
    </style>
  </head>

  <body>
    <!-- LOGIN -->
    <div id="authPage">
      <div class="auth-box">
        <h2>Login</h2>
        <input type="text" id="username" placeholder="Username" />
        <input type="password" id="password" placeholder="Password" />
        <button onclick="login()">Login</button>
        <button onclick="register()">Register</button>
      </div>
    </div>

    <!-- NAV -->
    <nav id="navbar">
      <div>
        <a href="#" onclick="showSection('home')">Home</a>
        <a href="#" onclick="showSection('shop')">Shop</a>
        <a href="#" onclick="showSection('contact')">Contact</a>
        <a href="#" onclick="showSection('checkout')">Checkout</a>
      </div>
      <div>
        🛒 <span id="count">0</span> | $<span id="total">0</span>
        <button onclick="toggleTheme()">🌙</button>
      </div>
    </nav>

    <!-- HOME -->
    <div id="home" class="section active">
      <h1>Welcome to Bike World 🚴</h1>
      <p>Premium Bikes with 25% Discount 🔥</p>
    </div>

    <!-- SHOP -->
    <div id="shop" class="section">
      <h1>Bike Collection</h1>
      <div class="bike-grid">
        <div class="bike-card">
          <img src="moutain.jpg" />
          <h3>Mountain Beast</h3>
          <p>Built for rugged terrains and off-road trails</p>
          <p>$524</p>
          <button onclick="addCart('Mountain Beast', 524)">Add to Cart</button>
        </div>
        <div class="bike-card">
          <img src="urban.jpg" />
          <h3>Urban Racer</h3>
          <p>Lightweight frame for speed and agility.</p>
          <p>$449</p>
          <button onclick="addCart('Urban Racer', 449)">Add to Cart</button>
        </div>
        <div class="bike-card">
          <img src="electric.jpg" />
          <h3>Electric Pro</h3>
          <p>Eco-friendly and cost-efficient for daily commutes</p>
          <p>$374</p>
          <button onclick="addCart('Electric Pro', 374)">Add to Cart</button>
        </div>
        <div class="bike-card">
          <img src="yamaha.jpg" />
          <h3>yamaha bike</h3>
          <p>Known for reliability and advanced engineering</p>
          <p>$956</p>
          <button onclick="addCart('yamaha bike', 374)">Add to Cart</button>
        </div>
        <div class="bike-card">
          <img src="Honda.jpg" />
          <h3>Honda</h3>
          <p>Reliable engine with low maintenance</p>
          <p>$374</p>
          <button onclick="addCart('Honda', 374)">Add to Cart</button>
        </div>
        <div class="bike-card">
          <img src="honda 15022.jpg" />
          <h3>Honda 150cc Racer</h3>
          <p>Built for speed and racing performance</p>
          <p>$374</p>
          <button onclick="addCart('honda150cc', 374)">Add to Cart</button>
        </div>
      </div>
    </div>

    <!-- CONTACT -->
    <div id="contact" class="section">
      <h1>Contact Us</h1>
      <div class="contact-container">
        <div class="contact-info">
          <p>📞 9842625154</p>
          <p>📧 sam123@gmail.com</p>
          <p>📍 Bike Street, NY</p>
        </div>
        <form class="contact-form" onsubmit="sendForm(event)">
          <input type="text" placeholder="Full Name" required />
          <input type="email" placeholder="Email" required />
          <textarea placeholder="Message" required></textarea>
          <button type="submit">Send Message</button>
        </form>
      </div>
    </div>

    <div id="checkout" class="section">
      <h1>Checkout</h1>
      <div id="cartItems"></div>
      <button onclick="placeOrder()">Place Order</button>
    </div>

    <div class="chatbot">
      <button onclick="toggleChat()">💬</button>
      <div class="chatbox" id="chatbox">
        <div class="chat-header">Bike Assistant</div>
        <div class="chat-messages" id="messages"></div>
        <div class="chat-input">
          <input type="text" id="msg" />
          <button onclick="sendMsg()">Send</button>
        </div>
      </div>
    </div>

    <script>
      let cart = [];

      /* REGISTER */
      function register() {
        const u = document.getElementById("username").value.trim();
        const p = document.getElementById("password").value.trim();

        if (u.length < 3 || p.length < 4) {
          alert("Username min 3 characters & password min 4 characters");
          return;
        }

        localStorage.setItem("user_" + u, p);
        alert("Registered Successfully! Now login.");
      }

      /* LOGIN */
      function login() {
        const u = document.getElementById("username").value.trim();
        const p = document.getElementById("password").value.trim();
        const saved = localStorage.getItem("user_" + u);

        if (!saved) {
          alert("User not found. Please register first.");
          return;
        }

        if (saved === p) {
          document.getElementById("authPage").style.display = "none";
          document.getElementById("navbar").style.display = "flex";
          showSection("home");
        } else {
          alert("Wrong Password!");
        }
      }

      /* SECTION SWITCH */
      function showSection(id) {
        document
          .querySelectorAll(".section")
          .forEach((sec) => sec.classList.remove("active"));
        document.getElementById(id).classList.add("active");
        if (id === "checkout") renderCart();
      }

      /* CART */
      function addCart(name, price) {
        cart.push({ name, price });
        updateCart();
      }

      function updateCart() {
        document.getElementById("count").innerText = cart.length;
        document.getElementById("total").innerText = cart.reduce(
          (sum, item) => sum + item.price,
          0,
        );
      }

      function renderCart() {
        const box = document.getElementById("cartItems");
        box.innerHTML = "";
        cart.forEach((item) => {
          box.innerHTML += `<p>${item.name} - $${item.price}</p>`;
        });
      }

      function placeOrder() {
        if (cart.length === 0) {
          alert("Cart is empty!");
          return;
        }
        alert("Order placed successfully!");
        cart = [];
        updateCart();
        renderCart();
      }

      /* SEARCH */
      function searchBike() {
        const value = document.getElementById("search").value.toLowerCase();
        document.querySelectorAll(".bike-card").forEach((card) => {
          card.style.display = card.innerText.toLowerCase().includes(value)
            ? "block"
            : "none";
        });
      }

      /* DARK MODE */
      function toggleTheme() {
        document.body.classList.toggle("light");
      }

      /* CONTACT */
      function sendForm(e) {
        e.preventDefault();
        alert("Message Sent Successfully!");
        e.target.reset();
      }

      /* CHAT */
      function toggleChat() {
        const box = document.getElementById("chatbox");
        box.style.display = box.style.display === "flex" ? "none" : "flex";
      }

      function sendMsg() {
        const input = document.getElementById("msg");
        const text = input.value.trim();
        if (!text) return;

        addMessage(text, "user");

        let reply = "Ask about price or discount.";

        if (text.toLowerCase().includes("price")) {
          reply = "Prices range from $374 to $956.";
        }

        if (text.toLowerCase().includes("discount")) {
          reply = "Currently, no discounts are available.";
        }

        if (text.toLowerCase().includes("hi")) {
          reply = "Hello Rider 🚴";
        }

        if (text.toLowerCase().includes("bikes")) {
          reply =
            "We have Mountain Beast, Urban Racer, Electric Pro, Yamaha, and Honda models.";
        }

        if (text.toLowerCase().includes("mountain")) {
          reply = "Mountain Beast is perfect for rugged terrains.";
        }

        if (text.toLowerCase().includes("urban")) {
          reply = "Urban Racer is designed for city commuting.";
        }

        if (text.toLowerCase().includes("electric")) {
          reply = "Electric Pro gives you eco-friendly assisted riding.";
        }

        if (text.toLowerCase().includes("yamaha")) {
          reply = "Yamaha bike offers premium performance and reliability.";
        }

        if (text.toLowerCase().includes("honda")) {
          reply = "Honda bikes are affordable and practical for daily use.";
        }

        if (text.toLowerCase().includes("racer")) {
          reply = "Honda 150cc Racer is built for speed and racing fun.";
        }

        setTimeout(() => addMessage(reply, "bot"), 500);
        input.value = "";
      }

      function addMessage(text, type) {
        const div = document.createElement("div");
        div.className = type;
        div.innerText = text;
        document.getElementById("messages").appendChild(div);
      }
    </script>
  </body>
</html>
